{
  "name": "fragile-action",
  "version": "1.0.0",
  "description": "Find the files you are afraid to touch",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "ncc build src/index.js -o dist"
  },
  "keywords": [
    "github-action",
    "code-quality",
    "risk-analysis"
  ],
  "author": "patchwork-eng",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": ["js", "mjs"],
    "testMatch": ["**/__tests__/**/*.test.js"]
  }
}
